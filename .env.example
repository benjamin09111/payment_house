# Configuración del Servidor
PORT=3000

# Base de Datos (Neon.tech PostgreSQL)
# Reemplaza esto con tu Connection String de Neon
DATABASE_URL="postgresql://USUARIO:PASSWORD@ep-server-name.region.aws.neon.tech/neondb?sslmode=require"

# Credenciales de Mercado Pago
# Puedes obtenerlas en tu panel de desarrolladores de MP: https://www.mercadopago.com/developers/panel
MP_ACCESS_TOKEN="APP_USR-tu-access-token-aqui"
MP_WEBHOOK_SECRET="tu-webhook-secret-aqui" # Útil para validar que los webhooks vienen de MP

# Seguridad para tus Apps
# Dominios permitidos separados por comas (ej: https://danza.com,https://nutricion.com)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
API_KEY_SECRET="clave_secreta_super_segura_para_mis_apps"
