<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Casa de Pagos | Dashboard General</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --success: #22c55e;
            --pending: #eab308;
            --error: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            padding: 2rem;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            font-size: 1.875rem;
            font-weight: 700;
            background: linear-gradient(to right, #818cf8, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .card {
            background: var(--card-bg);
            padding: 1.5rem;
            border-radius: 1rem;
            border: 1px border #334155;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-4px);
        }

        .card-label {
            color: var(--text-muted);
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .card-value {
            font-size: 2rem;
            font-weight: 700;
        }

        .card-value.revenue {
            color: var(--success);
        }

        .card-value.mrr {
            background: linear-gradient(to right, #34d399, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .table-container {
            background: var(--card-bg);
            border-radius: 1rem;
            overflow-y: auto;
            max-height: 480px;
            /* Viewport limit */
            border: 1px solid #334155;
        }

        /* Bonitos scrollbars para la tabla */
        .table-container::-webkit-scrollbar {
            width: 8px;
        }

        .table-container::-webkit-scrollbar-track {
            background: #0f172a;
        }

        .table-container::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 4px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            background: #111827;
            padding: 1rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--text-muted);
            letter-spacing: 0.05em;
        }

        td {
            padding: 1rem;
            border-bottom: 1px solid #334155;
            font-size: 0.875rem;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .status-approved {
            background: rgba(34, 197, 94, 0.1);
            color: var(--success);
        }

        .status-pending {
            background: rgba(234, 179, 8, 0.1);
            color: var(--pending);
        }

        .status-rejected {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .app-badge {
            background: #475569;
            color: white;
            padding: 0.125rem 0.5rem;
            border-radius: 0.375rem;
            font-size: 0.75rem;
        }

        /* Animaciones */
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-in {
            animation: fadeInDown 0.5s ease-out backwards;
        }

        /* Accordion para Desgloses */
        .accordion {
            background: var(--card-bg);
            border-radius: 1rem;
            margin-bottom: 2rem;
            border: 1px solid #334155;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .accordion summary {
            padding: 1.5rem 2rem;
            font-size: 1.25rem;
            font-weight: 600;
            cursor: pointer;
            list-style: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
        }

        .accordion summary::-webkit-details-marker {
            display: none;
        }

        .accordion summary::after {
            content: "▼";
            color: var(--primary);
            font-size: 1.25rem;
            transition: transform 0.3s ease;
        }

        .accordion[open] summary::after {
            transform: rotate(180deg);
        }

        .accordion-content {
            padding: 0 2rem 2rem 2rem;
            animation: fadeInDown 0.3s ease;
        }

        @media (max-width: 640px) {
            body {
                padding: 1rem;
            }

            .card-value {
                font-size: 1.5rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <header class="animate-fade-in" style="animation-delay: 0.1s;">
            <div>
                <h1>La Casa de Pagos</h1>
                <p style="color: var(--text-muted);">Panel de Control General</p>
                <a href="/dashboard/apps"
                    style="color: var(--primary); font-size: 0.875rem; text-decoration: none; margin-top: 0.5rem; display: inline-block;">⚙️
                    Gestionar Aplicaciones</a>
            </div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">
                Actualizado: <%= new Date().toLocaleString() %>
            </div>
        </header>

        <div class="stats-grid animate-fade-in" style="animation-delay: 0.2s;">
            <div class="card" style="border-left: 4px solid var(--success);">
                <div class="card-label">MRR (Suscripciones Activas) ✨</div>
                <div class="card-value mrr">$<%= stats.mrr.toLocaleString('es-AR') %>
                </div>
            </div>
            <div class="card">
                <div class="card-label">Ingresos Pagos Únicos</div>
                <div class="card-value revenue">$<%= stats.one_time_revenue.toLocaleString('es-AR') %>
                </div>
            </div>
            <div class="card">
                <div class="card-label">Ventas Totales</div>
                <div class="card-value">
                    <%= stats.total_transactions %>
                </div>
            </div>
        </div>

        <details class="accordion animate-fade-in" style="animation-delay: 0.3s;">
            <summary>Desglose por Aplicación</summary>
            <div class="accordion-content">
                <div class="stats-grid" style="margin-bottom: 0;">
                    <% if (stats.all_apps.length===0) { %>
                        <div style="color: var(--text-muted); font-size: 0.875rem;">Aún no tienes aplicaciones
                            registradas en este entorno. Crea una para comenzar a visualizar datos.</div>
                        <% } else { %>
                            <% stats.all_apps.forEach(app=> {
                                const oneTimeData = stats.breakdown_by_app.find(b => b.app_id === app.app_key &&
                                b.payment_type === 'one_time');
                                const subData = stats.breakdown_by_app.find(b => b.app_id === app.app_key &&
                                b.payment_type === 'subscription');

                                const amountOneTime = oneTimeData ? oneTimeData._sum.amount : 0;
                                const countOneTime = oneTimeData ? oneTimeData._count.id : 0;

                                const amountSub = subData ? subData._sum.amount : 0;
                                const countSub = subData ? subData._count.id : 0;

                                const totalAmount = (amountOneTime || 0) + (amountSub || 0);
                                const totalCount = (countOneTime || 0) + (countSub || 0);
                                %>
                                <div class="card" style="border-left: 4px solid var(--primary);">
                                    <div class="card-label" style="display: flex; flex-direction: column;">
                                        <strong style="font-size: 1rem; color: var(--text);">
                                            <%= app.name %>
                                        </strong>
                                        <span
                                            style="font-size: 0.75rem; font-family: monospace; opacity: 0.7; margin-top: 0.25rem;">ID:
                                            <%= app.app_key %>
                                        </span>
                                    </div>
                                    <div
                                        style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 1rem;">
                                        <div>
                                            <div
                                                style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                                                Total Ingresos</div>
                                            <div style="font-size: 1.5rem; font-weight: 700;">$<%=
                                                    totalAmount.toLocaleString('es-AR') %>
                                            </div>
                                            <div
                                                style="font-size: 0.75rem; color: var(--success); margin-top: 0.25rem;">
                                                +$<%= (amountSub || 0).toLocaleString('es-AR') %> recurrentes
                                            </div>
                                        </div>
                                        <div style="text-align: right;">
                                            <div style="font-size: 0.75rem; color: var(--text-muted);">Ventas</div>
                                            <div style="font-size: 1.125rem; font-weight: 600;">
                                                <%= totalCount %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>
                </div>
            </div>
        </details>

        <h2 class="animate-fade-in" style="margin-bottom: 1.5rem; font-size: 1.25rem; animation-delay: 0.4s;">Últimas
            Transacciones</h2>
        <div class="table-container animate-fade-in" style="animation-delay: 0.5s;">
            <table>
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>App</th>
                        <th>Descripción</th>
                        <th>Monto</th>
                        <th>Estado</th>
                        <th>Tipo</th>
                        <th>Referencia Ext.</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.forEach(tx=> { %>
                        <tr>
                            <td>
                                <%= new Date(tx.createdAt).toLocaleDateString() %>
                            </td>
                            <td><span class="app-badge">
                                    <%= tx.app_id %>
                                </span></td>
                            <td>
                                <%= tx.description %>
                            </td>
                            <td style="font-weight: 600;">$<%= tx.amount.toLocaleString('es-AR') %>
                            </td>
                            <td>
                                <span class="status-badge status-<%= tx.status %>">
                                    <%= tx.status %>
                                </span>
                            </td>
                            <td>
                                <% if (tx.payment_type==='subscription' ) { %>
                                    <span
                                        style="font-size: 0.75rem; background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 0.125rem 0.5rem; border-radius: 9999px;">🔁
                                        Suscripción</span>
                                    <% } else { %>
                                        <span
                                            style="font-size: 0.75rem; background: rgba(148, 163, 184, 0.1); color: var(--text-muted); padding: 0.125rem 0.5rem; border-radius: 9999px;">Una
                                            vez</span>
                                        <% } %>
                            </td>
                            <td style="font-family: monospace; color: var(--text-muted);">
                                <%= tx.external_reference %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>

</html>